{{- /* =====================================================================================
   SCHEMA EXPORT - JSON FORMAT - v4.1.0 (MySQL 5.7.6+)
   =====================================================================================
   REQUIREMENTS: MySQL 5.7.6+ (JSON_OBJECT with GROUP_CONCAT, GENERATION_EXPRESSION)
   {{- if .IncludeAdmin }}
   ADMIN: Includes mysql.innodb_index_stats for index sizes (requires SELECT on mysql.*)
   {{- end }}
   NOTE: For MySQL 8.0+, use -driver mysql for better performance
   ===================================================================================== */ -}}

{{if .StoredProc}}
DELIMITER $$

USE {{.DBName}}$$

DROP PROCEDURE IF EXISTS {{.SPName}}$$

CREATE PROCEDURE {{.SPName}}()
    COMMENT 'Export database schema as JSON (MySQL 5.7)'
BEGIN
    SET SESSION group_concat_max_len = 10000000;
{{else}}
SET SESSION group_concat_max_len = 10000000;
{{end}}
SELECT JSON_OBJECT(
    'fk_info', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', kcu.TABLE_SCHEMA,
                'table', kcu.TABLE_NAME,
                'column', kcu.COLUMN_NAME,
                'foreign_key_name', kcu.CONSTRAINT_NAME,
                'reference_schema', kcu.REFERENCED_TABLE_SCHEMA,
                'reference_table', kcu.REFERENCED_TABLE_NAME,
                'reference_column', kcu.REFERENCED_COLUMN_NAME,
                'fk_def', CONCAT('FOREIGN KEY (', kcu.COLUMN_NAME, ') REFERENCES ',
                    kcu.REFERENCED_TABLE_NAME, '(', kcu.REFERENCED_COLUMN_NAME, ') ON UPDATE ',
                    rc.UPDATE_RULE, ' ON DELETE ', rc.DELETE_RULE)
            )
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.KEY_COLUMN_USAGE kcu
        JOIN INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS rc
            ON kcu.CONSTRAINT_NAME = rc.CONSTRAINT_NAME
            AND kcu.CONSTRAINT_SCHEMA = rc.CONSTRAINT_SCHEMA
        WHERE kcu.REFERENCED_TABLE_NAME IS NOT NULL
            AND kcu.TABLE_SCHEMA = DATABASE()
    ), JSON_ARRAY()),

    'pk_info', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', TABLE_SCHEMA,
                'table', TABLE_NAME,
                'column', COLUMN_NAME,
                'pk_def', CONCAT('PRIMARY KEY (', COLUMN_NAME, ')')
            )
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.KEY_COLUMN_USAGE
        WHERE CONSTRAINT_NAME = 'PRIMARY'
            AND TABLE_SCHEMA = DATABASE()
    ), JSON_ARRAY()),

    'columns', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', TABLE_SCHEMA,
                'table', TABLE_NAME,
                'name', COLUMN_NAME,
                'type', LOWER(DATA_TYPE),
                'ordinal_position', ORDINAL_POSITION,
                'character_maximum_length', IFNULL(CAST(CHARACTER_MAXIMUM_LENGTH AS CHAR), 'null'),
                'precision', CASE
                    WHEN DATA_TYPE IN ('decimal', 'numeric')
                    THEN JSON_OBJECT('precision', NUMERIC_PRECISION, 'scale', NUMERIC_SCALE)
                    ELSE NULL END,
                'nullable', IS_NULLABLE = 'YES',
                'default', IFNULL(COLUMN_DEFAULT, ''),
                'collation', IFNULL(COLLATION_NAME, ''),
                'is_identity', EXTRA LIKE '%auto_increment%',
                'comment', IFNULL(COLUMN_COMMENT, ''),
                'generated_expression', CASE WHEN EXTRA LIKE '%GENERATED%' THEN IFNULL(GENERATION_EXPRESSION, '') ELSE '' END,
                'generated_type', CASE WHEN EXTRA LIKE '%STORED GENERATED%' THEN 'STORED'
                                       WHEN EXTRA LIKE '%VIRTUAL GENERATED%' OR EXTRA LIKE '%VIRTUAL%' THEN 'VIRTUAL'
                                       ELSE '' END
            )
            ORDER BY TABLE_NAME, ORDINAL_POSITION
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = DATABASE()
    ), JSON_ARRAY()),

    'indexes', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', s.TABLE_SCHEMA,
                'table', s.TABLE_NAME,
                'name', s.INDEX_NAME,
                'column', s.COLUMN_NAME,
                'index_type', LOWER(s.INDEX_TYPE),
                'cardinality', IFNULL(s.CARDINALITY, 0),
{{- if .IncludeAdmin }}
                'size', IFNULL(ist.size_bytes, -1),
{{- else }}
                'size', -1,
{{- end }}
                'direction', IF(s.COLLATION = 'D', 'desc', 'asc'),
                'column_position', s.SEQ_IN_INDEX,
                'unique', s.NON_UNIQUE = 0
            )
            ORDER BY s.TABLE_NAME, s.INDEX_NAME, s.SEQ_IN_INDEX
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.STATISTICS s
{{- if .IncludeAdmin }}
        LEFT JOIN (
            SELECT database_name, table_name, index_name,
                   SUM(stat_value * @@innodb_page_size) AS size_bytes
            FROM mysql.innodb_index_stats WHERE stat_name = 'size'
            GROUP BY database_name, table_name, index_name
        ) ist ON ist.database_name = s.TABLE_SCHEMA
             AND ist.table_name = s.TABLE_NAME
             AND ist.index_name = s.INDEX_NAME
{{- end }}
        WHERE s.TABLE_SCHEMA = DATABASE()
    ), JSON_ARRAY()),

    'tables', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', TABLE_SCHEMA,
                'table', TABLE_NAME,
                'rows', IFNULL(TABLE_ROWS, 0),
                'type', TABLE_TYPE,
                'engine', IFNULL(ENGINE, ''),
                'collation', IFNULL(TABLE_COLLATION, ''),
                'data_size', IFNULL(DATA_LENGTH, 0),
                'index_size', IFNULL(INDEX_LENGTH, 0),
                'auto_increment', IFNULL(AUTO_INCREMENT, 0),
                'comment', IFNULL(TABLE_COMMENT, '')
            )
            ORDER BY TABLE_NAME
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.TABLES
        WHERE TABLE_SCHEMA = DATABASE()
            AND TABLE_TYPE = 'BASE TABLE'
    ), JSON_ARRAY()),

    'views', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', TABLE_SCHEMA,
                'view_name', TABLE_NAME,
                'view_definition', ''
            )
            ORDER BY TABLE_NAME
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.VIEWS
        WHERE TABLE_SCHEMA = DATABASE()
    ), JSON_ARRAY()),

    'triggers', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', TRIGGER_SCHEMA,
                'table', EVENT_OBJECT_TABLE,
                'name', TRIGGER_NAME,
                'timing', ACTION_TIMING,
                'event', EVENT_MANIPULATION,
                'statement', ''
            )
            ORDER BY EVENT_OBJECT_TABLE, TRIGGER_NAME
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.TRIGGERS
        WHERE TRIGGER_SCHEMA = DATABASE()
    ), JSON_ARRAY()),

    'stored_procedures', IFNULL((
        SELECT CAST(CONCAT('[', GROUP_CONCAT(
            JSON_OBJECT(
                'schema', ROUTINE_SCHEMA,
                'name', ROUTINE_NAME,
                'type', ROUTINE_TYPE,
                'return_type', IFNULL(DATA_TYPE, ''),
                'comment', IFNULL(ROUTINE_COMMENT, ''),
                'parameters', JSON_ARRAY()
            )
            ORDER BY ROUTINE_TYPE, ROUTINE_NAME
        SEPARATOR ','), ']') AS JSON)
        FROM INFORMATION_SCHEMA.ROUTINES
        WHERE ROUTINE_SCHEMA = DATABASE()
    ), JSON_ARRAY()),

    'database_name', DATABASE(),
    'version', VERSION()
) AS metadata_json_to_import;
{{if .StoredProc}}
END$$

DELIMITER ;
{{end}}
